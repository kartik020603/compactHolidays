generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Story {
  id        String   @id @default(cuid())
  title     String
  author    String
  date      String
  content   String   @db.Text
  imageUrl  String?  @db.Text
  createdAt DateTime @default(now())
}
